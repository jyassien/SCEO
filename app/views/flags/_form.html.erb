<%= form_with(model: flag) do |form| %>
  <% if flag.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(flag.errors.count, "error") %> prohibited this flag from being saved:</h2>

      <ul>
        <% flag.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :reason, style: "display: block" %>
    <%= form.text_field :reason %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :flagged_by, style: "display: block" %>
    <%= form.text_field :flagged_by %>
  </div>

  <div>
    <%= form.label :flagged_at, style: "display: block" %>
    <%= form.datetime_field :flagged_at %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
